--- !u!1001 &1791643201
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: lines.Array.size
      value: 10
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[0]'
      value: 'Player: "Do you know where Zeus is at"'
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[1]'
      value: 'NPC: "your looking for zeus huh, well hes here but no one actually
        knows where"'
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[2]'
      value: 'Player: "Stop with the small talk '
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[3]'
      value: 'NPC: "Who do you think you are"'
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[4]'
      value: 'Player: "TELL ME WHERE HE IS, OR ILL KILL YOU"'
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[5]'
      value: 'NPC: "Theres a rumor that goes around in this town that if you find
        4 of zeus lightning bolts you can summon zeus"'
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[6]'
      value: 'Player: "Where can I find theese Lightening Bolts?"'
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[7]'
      value: 'NPC: "There scattered throughout the map hidden, no one has yet to
        find all four, and no one dare tries, your bold stranger"'
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[8]'
      value: 'NPC: "I need to warn you, some of the bolts are such strong voltage
        that they will kill you if you pick them up so be careful '
      objectReference: {fileID: 0}
    - target: {fileID: 452496079422518484, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: 'lines.Array.data[9]'
      value: 'Player: "Ill find thoose bolts and kill zeus watch"'
      objectReference: {fileID: 0}
    - target: {fileID: 5807729752010383816, guid: 5743405eec26fec409b8d3603053bafc, type: 3}
      propertyPath: m_Name
      value: NPC_Interactions (1)
      objectReference: {fileID: 0}
